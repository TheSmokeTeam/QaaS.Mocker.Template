{
  "$schema": "http://json.schemastore.org/template",
  "author": "SmokeTeam",
  "classifications": [
    ".NET",
    "QaaS",
    "Mocker",
    "Rider",
    "Docker",
    "Template"
  ],
  "name": "QaaS Mocker Project",
  "identity": "SmokeTeam.QaaS.Mocker.Project.1.1.0",
  "shortName": [
    "qaas-mocker"
  ],
  "description": "Creates a minimal Rider-friendly QaaS mocker project with Docker and GitHub Actions support.",
  "sourceName": "QaaS.Mocker.Template",
  "preferNameDirectory": true,
  "primaryOutputs": [
    {
      "path": "QaaS.Mocker.Template/QaaS.Mocker.Template.csproj"
    }
  ],
  "guids": [
    "9C8C88E7-0B36-4AF1-A0E2-86483756EBA9"
  ],
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "skipRestore": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Skips the automatic NuGet restore step after project creation."
    }
  },
  "postActions": [
    {
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "description": "Restore NuGet packages required by this project.",
      "manualInstructions": [
        {
          "text": "Run 'dotnet restore <your-solution>.sln --configfile NuGet.config'."
        }
      ],
      "continueOnError": true,
      "condition": "(!skipRestore)",
      "args": {
        "files": "QaaS.Mocker.Template.sln"
      }
    }
  ]
}
